!!! 5
%html
  %head
    %meta{ charset: 'UTF-8' }
    %meta{ name: 'viewport', content: 'width=device-width, initial-scale=1.0' }
    %title Columbus Crew Roster API
    %link{ href: '/stylesheets/styles.css', rel: 'stylesheet', type: 'text/css' }
  %body
    %main.container
      %h1 Columbus Crew Roster
      %p.subhead
        Live scrape target:
        %code https://www.columbuscrew.com/roster/
      %p
        API endpoints:
        %code /players
        and
        %code /players/:id
      %button#view-json.button{ type: 'button' } View Raw JSON
      %section#players.cards{ 'aria-live': 'polite' }

    #json-modal.modal.hidden{ 'aria-hidden': 'true' }
      .modal-backdrop{ 'data-close-modal': 'true' }
      .modal-dialog{ role: 'dialog', 'aria-modal': 'true', 'aria-labelledby': 'json-modal-title' }
        .modal-header
          %h2#json-modal-title Players JSON
          %button#close-json-modal.modal-close{ type: 'button', 'aria-label': 'Close JSON modal' } Close
        %pre#json-output.modal-body Loading...

    #player-focus-modal.focus-modal.hidden{ 'aria-hidden': 'true' }
      .focus-backdrop{ 'data-close-player-modal': 'true' }
      .focus-panel{ role: 'dialog', 'aria-modal': 'true', 'aria-labelledby': 'player-focus-title' }
        %button#close-player-focus.focus-close{ type: 'button', 'aria-label': 'Close player details' } Close
        #player-focus-content

    %script{ src: '/js/scripts.js', defer: true }
